{
  "name": "language-maxscript",
  "displayName": "Language MaxScript",
  "description": "Autodesk 3ds Max MaxScript language support",
  "icon": "mxs.png",
  "author": "Atelier Bump",
  "license": "MIT",
  "version": "2.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/HAG87/vscode-maxscript-lsp"
  },
  "homepage": "https://github.com/HAG87/vscode-maxscript-lsp",
  "publisher": "atelierbump",
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "MaxScript",
    "max script"
  ],
  "engines": {
    "vscode": "^1.91.0"
  },
  "main": "./out/extension.cjs",
  "type": "module",
  "contributes": {
    "languages": [
      {
        "id": "maxscript",
        "aliases": [
          "MaxScript",
          "maxscript",
          "mxs"
        ],
        "extensions": [
          ".ms",
          ".mcr"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "maxscript",
        "scopeName": "source.mxs",
        "path": "./syntaxes/maxscript.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "maxscript",
        "scopes": {
          "class": [
            "support.class.mxs"
          ],
          "classclass.defaultLibrary": [
            "support.class.mxs"
          ],
          "function.defaultLibrary": [
            "support.function.mxs"
          ],
          "interface": [
            "support.type.interface.mxs"
          ],
          "namespace": [
            "support.superclass.mxs"
          ],
          "struct": [
            "storage.type.struct.mxs"
          ],
          "type.defaultLibrary": [
            "support.type.primitive.mxs"
          ],
          "type": [
            "support.type.primitive.mxs"
          ],
          "variable": [
            "support.variable.system.mxs"
          ],
          "variable.other.readwrite": [
            "support.variable.system.mxs"
          ],
          "enum": [
            "support.variable.objectset.mxs"
          ],
          "enumMember": [
            "support.constant.mxs"
          ]
        }
      }
    ],
    "commands": [
      {
        "command": "mxs.help",
        "title": "Code reference...",
        "category": "MaxScript"
      },
      {
        "command": "mxs.minify",
        "title": "Minify open document",
        "category": "MaxScript",
        "icon": "$(package)"
      },
      {
        "command": "mxs.minify.file",
        "title": "Minify file",
        "category": "MaxScript"
      },
      {
        "command": "mxs.minify.files",
        "title": "Minify files...",
        "category": "MaxScript"
      },
      {
        "command": "mxs.prettify",
        "title": "Prettify document",
        "category": "MaxScript",
        "icon": "$(pencil)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mxs.minify",
          "when": "editorLangId  == maxscript && resourceExtname == .ms || resourceExtname == .mcr"
        },
        {
          "command": "mxs.prettify",
          "when": "editorLangId  == maxscript && resourceExtname == .ms || resourceExtname == .mcr"
        }
      ],
      "explorer/context": [
        {
          "command": "mxs.minify.file",
          "when": "resourceExtname == .ms || resourceExtname == .mcr",
          "group": "1_modification@1"
        }
      ],
      "editor/context": [
        {
          "command": "mxs.help",
          "when": "editorTextFocus && resourceLangId == maxscript",
          "group": "navigation@1"
        }
      ],
      "commandPalette": [
        {
          "command": "mxs.minify",
          "when": "editorLangId  == maxscript  && resourceExtname == .ms || resourceExtname == .mcr"
        },
        {
          "command": "mxs.minify.files"
        },
        {
          "command": "mxs.prettify",
          "when": "editorLangId  == maxscript  && resourceExtname == .ms || resourceExtname == .mcr"
        }
      ]
    },
    "configuration": [
      {
        "title": "Code Format",
        "properties": {
          "maxScript.formatter.indentChar": {
            "type": "string",
            "default": "\\t",
            "description": "Char sequence used to indent the code"
          },
          "maxScript.formatter.newLineChar": {
            "type": "string",
            "default": "\\r\\n",
            "description": "Char sequence to use as line break"
          },
          "maxScript.formatter.codeblock.parensInNewLine": {
            "type": "boolean",
            "default": true,
            "description": "Insert a line break after an opening paren and before a closing paren."
          },
          "maxScript.formatter.codeblock.newlineAllways": {
            "type": "boolean",
            "default": false,
            "description": "Allways add a line break after the opening parenthesis and before the closing parenthesis"
          },
          "maxScript.formatter.codeblock.spaced": {
            "type": "boolean",
            "default": true,
            "description": "Insert whitespace between expressions and sorrunding parentheses"
          },
          "maxScript.formatter.statements.useLineBreaks": {
            "type": "boolean",
            "default": true,
            "description": "Insert line breaks between a statement members"
          },
          "maxScript.formatter.statements.optionalWhitespace": {
            "type": "boolean",
            "default": false,
            "description": "Ommit whitespace when is unnecessary"
          },
          "maxScript.formatter.list.useLineBreaks": {
            "type": "boolean",
            "default": false,
            "description": "Insert line breaks in array-like objects"
          }
        }
      },
      {
        "title": "Prettifier",
        "properties": {
          "maxScript.prettifier.keepComments": {
            "type": "boolean",
            "default": true,
            "description": ""
          },
          "maxScript.prettifier.keepEmptyLines": {
            "type": "boolean",
            "default": true,
            "description": ""
          },
          "maxScript.prettifier.indentOnly": {
            "type": "boolean",
            "default": true,
            "description": ""
          },
          "maxScript.prettifier.expressionsToBlock": {
            "type": "boolean",
            "default": true,
            "description": ""
          },
          "maxScript.prettifier.filePrefix": {
            "type": "string",
            "default": "pretty_",
            "description": "Prefix for code prettyfier output"
          }
        }
      },
      {
        "title": "Minifier",
        "properties": {
          "maxScript.minifier.expressionsToBlock": {
            "type": "boolean",
            "default": true,
            "description": ""
          },
          "maxScript.minifier.removeUnnecessaryScopes": {
            "type": "boolean",
            "default": true,
            "description": ""
          },
          "maxScript.minifier.filePrefix": {
            "type": "string",
            "default": "min_",
            "description": "Prefix for code minify output"
          }
        }
      },
      {
        "title": "General",
        "properties": {
          "maxScript.parser.multiThreading": {
            "type": "boolean",
            "default": false,
            "description": "Enable multithreading. This feature can be unstable. Disable it if you encounter too many crashes using the extension."
          },
          "maxScript.help.provider": {
            "type": "string",
            "default": "https://help.autodesk.com/view/MAXDEV/2025/ENU/",
            "description": "MaxScript help source"
          }
        }
      }
    ],
    "snippets": [
      {
        "language": "maxscript",
        "path": "./snippets/maxscript.json"
      }
    ],
    "configurationDefaults": {
      "[maxscript]": {
        "editor.semanticHighlighting.enabled": true
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.cjs",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.cjs --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.cjs --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "generate": "antlr4ng -Dlanguage=TypeScript -visitor -Xexact-output-dir src/parser/grammars/mxsLexer.g4 src/parser/grammars/mxsParser.g4 -o src/parser"
  },
  "devDependencies": {
    "@types/moo": "^0.5.9",
    "@types/node": "^20.14.11",
    "@types/vscode": "^1.91.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "antlr4ng-cli": "^2.0.0",
    "esbuild": "^0.23.0",
    "eslint": "^8.57.0",
    "npm-run-all": "^4.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "antlr4-c3": "^3.4.1",
    "antlr4ng": "^3.0.4",
    "moo": "^0.5.2"
  }
}